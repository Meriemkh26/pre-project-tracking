          "id": "62dnRXaK9unX3e5f",
          "name": "MySQL account"
        }
      }
    },
    {
      "parameters": {
        "fromEmail": "projectsann2026@gmail.com",
        "toEmail": "={{ $json.teacher_email }}",
        "html": "=<h2>Pending Projects Reminder</h2>\n<p>Dear {{ $json.teacher_name }},</p>\n<p>This is a friendly reminder that the following project has been waiting for your review for more than 3 days:</p>\n<ul>\n  <li><strong>Project:</strong> {{ $json.title }}</li>\n  <li><strong>Student:</strong> {{ $json.student_name }}</li>\n  <li><strong>Submitted:</strong> {{ $json.submitted_at }}</li>\n</ul>\n<p>Please login to PFE Tracker and review it as soon as possible.</p>\n<br>\n<p>PFE Tracker System</p>",
        "options": {}
