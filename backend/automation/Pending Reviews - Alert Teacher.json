      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        0,
        0
      ],
      "id": "ba970f47-4601-465e-91b6-dff1c6ccee99",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT p.id, p.title, p.submitted_at, \n       u.name as student_name,\n       t.email as teacher_email,\n       t.name as teacher_name\nFROM projects p\nJOIN users u ON p.student_id = u.id\nJOIN users t ON p.teacher_id = t.id\nWHERE p.status = 'pending'\nAND p.submitted_at < NOW() - INTERVAL 3 DAY",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        208,
        0
      ],
      "id": "21d97d93-b14e-46ba-b3a1-305a79dbe0a1",
      "name": "Execute a SQL query",
