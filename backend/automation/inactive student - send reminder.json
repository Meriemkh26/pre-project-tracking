    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT p.id, p.title, p.submitted_at,\n       u.name as student_name,\n       u.email as student_email\nFROM projects p\nJOIN users u ON p.student_id = u.id\nWHERE p.status = 'in_progress'\nAND p.submitted_at < NOW() - INTERVAL 7 DAY",
        "options": {}
      },
