        }
      }
    },
    {
      "parameters": {
        "fromEmail": "projectsann2026@gmail.com",
        "toEmail": "={{ $json.student_email }}",
        "subject": "Reminder: Please update your PFE project",
        "html": "=<h2>Project Update Reminder</h2>\n<p>Dear {{ $json.student_name }},</p>\n<p>This is a friendly reminder that your PFE project has not been updated for more than 7 days.</p>\n<ul>\n  <li><strong>Project:</strong> {{ $json.title }}</li>\n  <li><strong>Submitted:</strong> {{ $json.submitted_at }}</li>\n</ul>\n<p>Please login to PFE Tracker and update your progress as soon as possible.</p>\n<p>Your supervisor is waiting for updates!</p>\n<br>\n<p>PFE Tracker System</p>",
